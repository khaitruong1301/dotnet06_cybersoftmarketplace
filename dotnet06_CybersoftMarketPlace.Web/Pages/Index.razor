@page "/"
@layout HomePageMaster

@inject ProductStateService _prodStateService;
@implements IDisposable

<div class="container-fluid">

    <h3>Cybersoft marketplace</h3>
    <div class="row">
        @foreach (ProductIndexPageDTO pro in _prodStateService.Products)
        {
            <div class="col-md-3 mt-2">
                <div class="card">
                    <img src="@pro.ImageUrl" class="card-img-top" alt="Product image">
                    <div class="card-body">
                        <h3 class="card-title">@pro.Name</h3>
                        <p class="card-text">Price: @pro.Price</p>
                        <p class="text-primary fst-italic">@pro.ProductCategory.Name</p>
                            <p class="text-success fw-bold">@pro.Shop.Name</p>
                            <p class="card-text">@pro.Shop.Description</p>
                        <button class="btn btn-primary">Add to Cart</button>
                    </div>
                </div>
            </div>
        }
    </div>


</div>


@code {


    protected override async Task OnInitializedAsync()
    {
        _prodStateService.OnChange += StateHasChanged;
       
        await _prodStateService.LoadProductsAsync();

    }

    public void Dispose()
    {
        _prodStateService.OnChange -= StateHasChanged;
    }


}


